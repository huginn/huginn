{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended"],
  labels: ["dependencies", "automerge"],
  prHourlyLimit: 0,
  prConcurrentLimit: 10,
  timezone: "Asia/Tokyo",
  schedule: ["after 9am and before 1pm on Saturday"],
  lockFileMaintenance: {
    enabled: true,
    schedule: ["after 9am and before 1pm on Friday"],
  },
  customManagers: [
    {
      customType: "regex",
      description: "Update Ruby versions in manual install docs",
      managerFilePatterns: [
        "/(^|/)doc/manual/(installation|update)\\.md$/",
      ],
      matchStrings: [
        "Ruby (?<currentValue>\\d+\\.\\d+\\.\\d+) installed",
        "cd ruby-(?<currentValue>\\d+\\.\\d+\\.\\d+)",
      ],
      depNameTemplate: "ruby",
      datasourceTemplate: "ruby-version",
    },
    {
      customType: "regex",
      description: "Update Ruby source archive URLs in manual install docs",
      managerFilePatterns: ["/(^|/)doc/manual/(installation|update)\\.md$/"],
      matchStrings: [
        "https://cache\\.ruby-lang\\.org/pub/ruby/\\d+\\.\\d+/ruby-(?<currentValue>\\d+\\.\\d+\\.\\d+)\\.tar\\.xz",
      ],
      depNameTemplate: "ruby",
      datasourceTemplate: "ruby-version",
      autoReplaceStringTemplate: "https://cache.ruby-lang.org/pub/ruby/{{{newMajor}}}.{{{newMinor}}}/ruby-{{{newValue}}}.tar.xz",
    },
    {
      customType: "regex",
      description: "Update Ruby versions in Docker base images",
      managerFilePatterns: ["/(^|/)docker/(multi|single)-process/Dockerfile$/"],
      matchStrings: [
        "FROM rubylang/ruby:(?<currentValue>\\d+\\.\\d+\\.\\d+)-\\S+",
      ],
      depNameTemplate: "ruby",
      datasourceTemplate: "ruby-version",
    },
  ],
  packageRules: [
    {
      groupName: "Ruby",
      matchDatasources: ["ruby-version"],
      matchPackageNames: ["ruby", "ruby-version"],
    },
    {
      matchDatasources: ["docker"],
      matchPackageNames: ["rubylang/ruby"],
      enabled: false,
    },
    {
      groupName: "patch updated gems",
      matchDatasources: ["rubygems"],
      matchUpdateTypes: ["patch", "digest"],
    },
    {
      groupName: "minor updated gems",
      matchDatasources: ["rubygems"],
      matchUpdateTypes: ["minor"],
    },
    {
      matchManagers: ["bundler"],
      postUpdateOptions: ["bundlerConservative"],
    },
    {
      matchDatasources: ["rubygems"],
      rangeStrategy: "bump",
    },
    {
      matchDatasources: ["rubygems"],
      matchPackageNames: [
        "ace-rails-ap",
        "bootsnap",
        "bootstrap-kaminari-views",
        "capistrano",
        "capistrano-bundler",
        "capistrano-rails",
        "capybara",
        "daemons",
        "debug",
        "delayed_job",
        "delayed_job_active_record",
        "em-http-request",
        "evernote_oauth",
        "execjs",
        "faraday",
        "faraday-follow_redirects",
        "faraday-gzip",
        "faraday-typhoeus",
        "foreman",
        "gmail_xoauth",
        "geokit",
        "geokit-rails",
        "google-apis-calendar_v3",
        "google-cloud-translate-v2",
        "haversine",
        "hipchat",
        "httmultiparty",
        "huginn_agent",
        "jquery-rails",
        "json",
        "jsonpath",
        "kramdown",
        "letter_opener_web",
        "listen",
        "logger",
        "mqtt",
        "multi_xml",
        "net-ftp",
        "net-ftp-list",
        "omniauth",
        "omniauth-evernote",
        "omniauth-tumblr",
        "omniauth-twitter",
        "ostruct",
        "pdf-reader",
        "pirate_weather_forecast_ruby",
        "puma",
        "rails-controller-testing",
        "rr",
        "rspec",
        "rspec-collection_matchers",
        "rspec-html-matchers",
        "rspec-mocks",
        "rspec-rails",
        "rspec-retry",
        "rturk",
        "rubocop",
        "rubocop-performance",
        "rubocop-rspec",
        "sassc-rails",
        "select2-rails",
        "selenium-webdriver",
        "simplecov",
        "simplecov-lcov",
        "slack-notifier",
        "spectrum-rails",
        "spring",
        "spring-commands-rspec",
        "spring-watcher-listen",
        "sprockets",
        "terser",
        "twilio-ruby",
        "typhoeus",
        "tzinfo-data",
        "uglifier",
        "vcr",
        "webmock",
        "xmpp4r",
      ],
      rangeStrategy: "update-lockfile",
    },
    {
      groupName: "development and test gems",
      matchDatasources: ["rubygems"],
      matchPackageNames: [
        "capistrano",
        "capistrano-bundler",
        "capistrano-rails",
        "capybara",
        "capybara-select-2",
        "debug",
        "letter_opener_web",
        "rails-controller-testing",
        "rr",
        "rspec",
        "rspec-collection_matchers",
        "rspec-html-matchers",
        "rspec-mocks",
        "rspec-rails",
        "rspec-retry",
        "rubocop",
        "rubocop-performance",
        "rubocop-rspec",
        "selenium-webdriver",
        "simplecov",
        "simplecov-lcov",
        "spring",
        "spring-commands-rspec",
        "spring-watcher-listen",
        "vcr",
        "webmock",
      ],
    },
  ],
  vulnerabilityAlerts: {
    enabled: true,
    addLabels: ["security"],
  },
  osvVulnerabilityAlerts: true,
}
